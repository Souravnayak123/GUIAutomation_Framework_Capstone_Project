<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationSuite">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="AutomationTests">

        <classes>

            <class name="tests.FormTest"/>
            <class name="tests.DatePickerTest"/>
            <class name="tests.FileUploadTest"/>
            <class name="tests.AlertTest"/>
            <class name="tests.MouseHoverTest"/>
            <class name="tests.DoubleClickTest"/>
            <class name="tests.DragAndDropTest"/>
            <class name="tests.SliderTest"/>
            <class name="tests.WindowHandlingTest"/>
            <class name="tests.PaginationTableTest"/>

            <class name="tests.WikipediaTest"/>
            <class name="tests.DynamicButtonTest"/>
            <class name="tests.HiddenElementsTest"/>
            <class name="tests.AjaxTest"/>
            <class name="tests.BrokenLinksTest"/>
            <class name="tests.SVGTest"/>
            <class name="tests.ScrollingDropdownTest"/>

            <!-- Run Last -->
            <class name="tests.PagesSectionTest"/>

        </classes>

    </test>

</suite>